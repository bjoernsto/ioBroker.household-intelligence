{
  "type": "tabs",
  "i18n": false,
  "items": {
    "tab_llm": {
      "type": "panel",
      "label": "LLM Backend",
      "items": {
        "llmBackend": {
          "type": "select",
          "label": "LLM Backend",
          "options": [
            { "label": "Ollama (lokal, empfohlen)", "value": "ollama" },
            { "label": "OpenAI (Cloud)", "value": "openai" }
          ],
          "default": "ollama",
          "sm": 12
        },
        "ollamaHost": {
          "type": "text",
          "label": "Ollama Host URL",
          "default": "http://localhost:11434",
          "hidden": "data.llmBackend !== 'ollama'",
          "sm": 12,
          "newLine": true
        },
        "ollamaModel": {
          "type": "text",
          "label": "Ollama Modell (z.B. mistral, llama3, phi4-mini)",
          "default": "mistral",
          "hidden": "data.llmBackend !== 'ollama'",
          "sm": 12,
          "newLine": true
        },
        "openaiApiKey": {
          "type": "password",
          "label": "OpenAI API Key",
          "hidden": "data.llmBackend !== 'openai'",
          "sm": 12,
          "newLine": true
        },
        "openaiModel": {
          "type": "select",
          "label": "OpenAI Modell",
          "options": [
            { "label": "GPT-4o mini (günstig)", "value": "gpt-4o-mini" },
            { "label": "GPT-4o (besser)", "value": "gpt-4o" }
          ],
          "default": "gpt-4o-mini",
          "hidden": "data.llmBackend !== 'openai'",
          "sm": 12,
          "newLine": true
        },
        "maxTokens": {
          "type": "number",
          "label": "Max. Tokens pro Anfrage",
          "default": 1500,
          "min": 500,
          "max": 4000,
          "sm": 6,
          "newLine": true
        },
        "timeoutSeconds": {
          "type": "number",
          "label": "Timeout in Sekunden",
          "default": 300,
          "min": 60,
          "max": 600,
          "sm": 6
        },
        "analysisIntervalHours": {
          "type": "select",
          "label": "Analyse-Intervall",
          "options": [
            { "label": "Jede Stunde", "value": 1 },
            { "label": "Alle 3 Stunden", "value": 3 },
            { "label": "Alle 6 Stunden (empfohlen)", "value": 6 },
            { "label": "Einmal täglich", "value": 24 }
          ],
          "default": 6,
          "sm": 6,
          "newLine": true
        }
      }
    },
    "tab_datapoints": {
      "type": "panel",
      "label": "Datenpunkte",
      "items": {
        "_dpHelp": {
          "type": "staticText",
          "text": "Trage hier deine Datenpunkte als JSON ein. Format: [{\"id\":\"hm-rpc.0.sensor.TEMPERATURE\",\"label\":\"Wohnzimmer Temp\",\"category\":\"temperature\",\"unit\":\"°C\"}]",
          "sm": 12
        },
        "datapointsJson": {
          "type": "jsonEditor",
          "label": "Datenpunkte (JSON)",
          "sm": 12,
          "newLine": true,
          "height": 300
        },
        "_dpExample": {
          "type": "staticText",
          "text": "Kategorien: power, temperature, heating, water, light, presence, security, solar, other",
          "sm": 12,
          "newLine": true
        }
      }
    },
    "tab_notifications": {
      "type": "panel",
      "label": "Benachrichtigungen",
      "items": {
        "notifyTelegram": {
          "type": "checkbox",
          "label": "Telegram (benötigt Telegram Adapter)",
          "sm": 12
        },
        "telegramUser": {
          "type": "text",
          "label": "Telegram Benutzername (leer = alle)",
          "hidden": "!data.notifyTelegram",
          "sm": 12,
          "newLine": true
        },
        "notifyPushover": {
          "type": "checkbox",
          "label": "Pushover (benötigt Pushover Adapter)",
          "sm": 12,
          "newLine": true
        },
        "notifyEmail": {
          "type": "checkbox",
          "label": "E-Mail (benötigt Email Adapter)",
          "sm": 12,
          "newLine": true
        },
        "emailTo": {
          "type": "text",
          "label": "E-Mail Empfänger",
          "hidden": "!data.notifyEmail",
          "sm": 12,
          "newLine": true
        }
      }
    }
  }
}
