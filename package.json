    "ollamaModel": "llama3",
    "openaiApiKey": "",
    "openaiModel": "gpt-4o-mini",
    "maxTokens": 1500,
    "timeoutSeconds": 60,
    "analysisIntervalHours": 6,
    "notifyTelegram": false,
    "notifyPushover": false,
    "notifyEmail": false,
