    "authors": ["ioBroker Community"],
    "keywords": ["AI", "LLM", "Ollama", "smarthome", "energy", "automation"],
    "license": "MIT",
    "type": "general",
    "main": "main.js",
    "icon": "admin/household-intelligence.png",
    "enabled": true,
    "mode": "daemon",
    "platform": "Javascript/Node.js",
    "loglevel": "info",
    "readme": "https://github.com/YOUR_USER/ioBroker.household-intelligence/blob/main/README.md",
    "messagebox": true,
    "allowInit": true,
    "compact": false,
    "connectionType": "local",
