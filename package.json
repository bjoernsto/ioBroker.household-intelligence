    "news": {
      "0.1.0": {
        "en": "Initial release",
        "de": "Erste Version"
      }
    },
    "title": "Household Intelligence",
    "titleLang": {
      "en": "Household Intelligence (AI Smart Home)",
      "de": "Household Intelligence (KI Smart Home)"
    },
    "desc": {
      "en": "AI-powered analysis, anomaly detection and automation suggestions for your smart home using local LLM (Ollama) or OpenAI.",
      "de": "KI-gestützte Analyse, Anomalie-Erkennung und Automationsvorschläge für dein Smart Home – mit lokalem LLM (Ollama) oder OpenAI."
